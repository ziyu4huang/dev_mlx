  "segments": [
    {
      "id": "seg_1",
      "character": "Narrator",
      "text": "二零一七年，Google 發表了一篇名為「Attention is All You Need」的論文，提出了 Transformer 架構。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "storytelling",
      "speed": 0.97
    },
    {
      "id": "seg_2",
      "character": "Narrator",
      "text": "它的核心創新是注意力機制，讓模型能夠同時關注輸入中的所有詞，理解詞與詞之間的關係。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "calm",
      "speed": 0.95
    },
    {
      "id": "seg_3",
      "character": "Narrator",
      "text": "這就像是閱讀時，你能同時看到整頁的內容，而不是逐字逐句地看。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "storytelling",
      "speed": 0.97
    },
    {
      "id": "seg_4",
      "character": "Narrator",
      "text": "Transformer 是 GPT、BERT、以及所有現代大語言模型的基礎。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "serious",
      "speed": 0.95
    }
  ]
}
