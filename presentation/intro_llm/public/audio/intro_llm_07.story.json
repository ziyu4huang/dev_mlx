    {
      "id": "seg_1",
      "character": "Narrator",
      "text": "如何有效地使用大語言模型？關鍵在於提示工程。好的提示要具體明確，提供足夠的上下文。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "storytelling",
      "speed": 0.97
    },
    {
      "id": "seg_2",
      "character": "Narrator",
      "text": "你可以用角色設定，例如告訴模型「你是一位經驗豐富的 Python 工程師」。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "calm",
      "speed": 0.95
    },
    {
      "id": "seg_3",
      "character": "Narrator",
      "text": "你也可以用逐步思考的方式，要求模型一步一步地推理。少樣本學習是指提供幾個範例讓模型參考。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "calm",
      "speed": 0.95
    },
    {
      "id": "seg_4",
      "character": "Narrator",
      "text": "掌握這些技巧，就能大幅提升模型的輸出品質。",
      "voice": "zm_yunjian",
      "lang": "zh",
      "emotion": "serious",
      "speed": 0.95
    }
  ]
}
